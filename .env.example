# VDA Trading Terminal – Environment Variables
# Copy this file to .env and fill in your values.
# The app works in demo/simulator mode without any of these set.

# ── Backend API ─────────────────────────────────────────────────────────────
# URL of the VDA backend REST API.
# When set, the frontend connects to the real backend for auth, orders, etc.
# For Docker Compose: http://localhost:5000
# Leave blank to run in standalone demo/simulator mode.
# REACT_APP_API_URL=http://localhost:5000

# ── MT4 Bridge ─────────────────────────────────────────────────────────────
# WebSocket URL of the backend server (also acts as MT4 bridge).
# Usually the same host as REACT_APP_API_URL but with ws:// scheme.
# For Docker Compose: ws://localhost:5000
# Leave blank to run in built-in simulator mode.
# REACT_APP_MT4_BRIDGE_URL=ws://localhost:5000

# ── Demo accounts (backend only) ───────────────────────────────────────────
# Super Admin: super@vda.trade  / Super1234!
# Admin:       admin@vda.trade  / Admin1234!
# Trader:      demo@vda.trade   / Demo1234!

# ── Optional: override the demo account display name ───────────────────────
# REACT_APP_ACCOUNT_NAME=VDA Demo Account
# REACT_APP_ACCOUNT_SERVER=VDABroker-Demo
