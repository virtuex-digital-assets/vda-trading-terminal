# VDA Trading Terminal – Environment Variables
# Copy this file to .env and fill in your values.
# The app works in demo/simulator mode without any of these set.

# ── MT4 Bridge ─────────────────────────────────────────────────────────────
# WebSocket URL of your MT4 Expert Advisor bridge server.
# Leave blank to run in built-in simulator mode.
# REACT_APP_MT4_BRIDGE_URL=ws://localhost:5000

# ── Optional: override the demo account display name ───────────────────────
# REACT_APP_ACCOUNT_NAME=VDA Demo Account
# REACT_APP_ACCOUNT_SERVER=VDABroker-Demo
